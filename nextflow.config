// Nextflow configuration for QTL2 Pipeline
// Single container approach for r/qtl2 and data manipulation

// Pipeline metadata
manifest {
    name            = 'QTL2_NF'
    author          = 'Dpbudke'
    homePage        = 'https://github.com/Dpbudke/QTL2_NF'
    description     = 'Nextflow pipeline for multiparental mouse QTL analysis using r/qtl2'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

// Default parameters
params {
    // Input files (generated from your pre-pipeline RMD)
    phenotype_file     = 'Data/QTL2_NF_meta_pheno_input.csv'
    finalreport_files  = 'Data/*FinalReport.txt'
    genotype_file      = null  // Will be added in future modules
    genetic_map        = null  // Will be added in future modules
    
    // Study configuration
    study_prefix       = 'MyStudy'
    auto_prefix_samples = false  // Set to true if you want automatic sample ID prefixing
    test_mode          = false   // Set to true to process chromosome 19 only (for development)

    // Analysis type preset (auto-configures outdir, sample_filter, exclude_covariates, interactive_covar)
    // Valid values: 'Diet_additive', 'Diet_interactive', 'AIN76_only', 'HC_only', or null (manual config)
    analysis_type      = null

    // Study type prefix for output directory (e.g. 'LCMS' or 'eQTL')
    // When set, outdir becomes Results_final/{study_type}/{analysis_type}
    // Default 'eQTL' so analysis_type runs land in Results_final/eQTL/{analysis_type}
    // Override with --study_type LCMS for metabolite analyses
    study_type         = 'eQTL'

    // Output directory (auto-computed at config-parse time from study_type + analysis_type)
    // Default: Results_final/{study_type}/{analysis_type}  e.g. Results_final/eQTL/Diet_additive
    outdir             = null  // Resolved by auto-compute block below
    
    // Process-specific parameters
    // Module 1: Phenotype Processing
    pheno_na_strings   = 'na,NA,N/A,'
    
    // Module 4: QTL Analysis Parameters
    lod_threshold      = 7.0    // LOD threshold for filtering QTLs before permutation testing
    interactive_covar  = null   // Optional: covariate to test as interactive term (e.g., 'Diet' for GxE interaction). If null, all covariates are additive.

    // Module 6b: Optional Regional QTL Filtering (before Module 7 permutation testing)
    qtl_region         = null   // Genomic region filter (e.g., "chr12:81-91" or "chr12" or "chr12:81-91;chr2:50-60")
    gtf_file           = 'Data/Mus_musculus.GRCm39.113.gtf.gz'  // Ensembl annotation v113 for gene locations

    // Module 7: Permutation Testing Parameters
    run_perm_benchmark = false  // Set to true to run performance benchmarking (adds 30-40 min)

    // Sample Filtering Parameters (JSON string for flexible subsetting)
    sample_filter      = null   // JSON filter for sample subsetting (e.g., '{"Sex": ["male"], "Diet": ["hc"]}')
    exclude_covariates = null   // Comma-separated list of covariates to exclude from model (e.g., 'Diet,batch')
    single_sex         = null   // Set to 'female' or 'male' for single-sex studies; auto-adds sex column if missing and prevents its removal from the cross object

    // Module 9: Visualization batching
    viz_qtls_per_batch   = 100     // QTLs per SLURM visualization batch

    // Module 10: TIMBR Allelic Series Analysis
    run_timbr            = true    // Module 10: TIMBR allelic series analysis (runs by default)
    timbr_sig_level      = "99%"   // filter QTLs at this significance level or above ("63%", "90%", "95%", "99%")
    timbr_qtls_per_batch = 20      // QTLs per SLURM batch job (matched to cpus for mclapply)
    timbr_samples        = 10000   // MCMC samples per TIMBR() call

    // DO Mixup QC Parameters (optional standalone analysis)
    run_mixup_qc       = false  // Set to true to run DO sample mixup QC analysis

    // Help message
    help               = false
}

// Auto-compute outdir from analysis_type / study_type if not explicitly provided via --outdir.
// This runs at config-parse time (before process definitions), so publishDir sees the correct value.
if (!params.outdir) {
    if (params.analysis_type) {
        params.outdir = params.study_type
            ? "Results_final/${params.study_type}/${params.analysis_type}"
            : "Results_final/${params.analysis_type}"
    } else {
        params.outdir = 'results'
    }
}

// Global work directory
workDir = "${projectDir}/nextflow_work"

// Process configuration
process {
    // Default settings for all processes
    shell = ['/bin/bash', '-euo', 'pipefail']
    
    // Single container for all processes
    container = 'dpbudke/qtl2-pipeline:latest'
    
    // SLURM executor for HPC
    executor = 'slurm'
    clusterOptions = '--account=do2_projects --partition=ceres'
    
    // Resource defaults
    cpus   = 2
    memory = '4 GB'
    time   = '2h'
    
    // Error handling
    errorStrategy = 'retry'
    maxRetries    = 2
    
    // Process-specific overrides
    withName: PHENOTYPE_PROCESS {
        cpus   = 4
        memory = '10 GB'
        time   = '1h'
    }
    
    // Module 2: Genotype processing (64GB for full dataset)
    withName: GENOTYPE_PROCESS {
        cpus   = 8
        memory = '128 GB'
        time   = '4h'
    }
    
    // Module 5: Parallel genome scan preparation
    withName: PREPARE_GENOME_SCAN_SETUP {
        cpus   = 128
        memory = '128 GB'
        time   = '4h'
    }

    withName: PREPARE_GENOME_SCAN_CHR_KINSHIP {
        cpus   = 4
        memory = '16 GB'
        time   = '1h'
    }

    withName: COMBINE_GENOME_SCAN_PREP {
        cpus   = 4
        memory = '16 GB'
        time   = '1h'
    }
    
    // Module 6: Phenotype-chunked genome scanning (priority-mem partition)
    withName: GENOME_SCAN_SETUP {
        cpus   = 4
        memory = '32 GB'
        time   = '1h'
    }

    withName: GENOME_SCAN_BATCH {
        cpus   = 96      // Optimized for batch processing (10 chunks per batch)
        memory = '1.6 TB'  // 1.6TB per batch, ~8 batches in parallel (13TB total limit)
        time   = '12h'   // Time allowance for batch processing
        clusterOptions = '--account=do2_projects --partition=ceres'
        // Parallel batch submission reduces infrastructure exposure
    }

    withName: COMBINE_BATCH_RESULTS {
        cpus   = 16
        memory = '256 GB'
        time   = '2h'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }

    // Module 6b: Optional Regional QTL Filtering
    withName: FILTER_PEAKS_BY_REGION {
        cpus   = 4
        memory = '16 GB'
        time   = '30m'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }

    // Module 7: Chunked Permutation Testing (DO_Pipe Approach)
    withName: PERM_SETUP {
        cpus   = 4
        memory = '32 GB'  // Reduced - just filtering phenotypes
        time   = '10m'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }

    withName: PERM_BENCHMARK {
        cpus   = 4
        memory = '1 TB'
        time   = '1h'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }

    // PERM_COORDINATOR: single long-lived SLURM job that submits and monitors
    // all permutation batch jobs independently of the Nextflow driver session.
    // No container — needs host sbatch/sacct tools. Batch workers are submitted
    // with apptainer exec directly from the coordinator's bash script.
    withName: PERM_COORDINATOR {
        cpus   = 1
        memory = '4 GB'
        time   = '7d'   // 7-day wall time covers any permutation run
        clusterOptions = '--account=do2_projects --partition=ceres'
        errorStrategy = 'terminate'   // Don't retry — coordinator has internal retry logic
        maxRetries = 0
    }

    withName: PERM_AGGREGATE {
        cpus   = 4
        memory = '32 GB'  // Aggregating 470 batch files
        time   = '1h'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }

    // Module 8: Significant QTL identification
    withName: IDENTIFY_SIGNIFICANT_QTLS {
        cpus   = 8
        memory = '128 GB'
        time   = '4h'
    }

    // Module 9: QTL Visualizations (batched)
    withName: VISUALIZE_SETUP {
        cpus   = 2
        memory = '8 GB'
        time   = '30m'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }
    withName: VISUALIZE_BATCH {
        cpus   = 16
        memory = { 128.GB * task.attempt }   // 128 GB attempt 1, 256 GB attempt 2
        time   = { 2.h  * task.attempt }     // 2h attempt 1, 4h attempt 2
        clusterOptions = '--account=do2_projects --partition=ceres'
        errorStrategy = 'retry'
        maxRetries    = 2
    }
    withName: VISUALIZE_AGGREGATE {
        cpus   = 2
        memory = '8 GB'
        time   = '30m'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }

    // Module 10: TIMBR Allelic Series Analysis
    withName: TIMBR_SETUP {
        cpus   = 4
        memory = '32 GB'
        time   = '30m'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }
    withName: TIMBR_BATCH {
        cpus   = 20
        memory = { 64.GB  * task.attempt }   // 64 GB attempt 1, 128 GB attempt 2
        time   = { 2.h   * task.attempt }    // 2h attempt 1, 4h attempt 2
        clusterOptions = '--account=do2_projects --partition=ceres'
        errorStrategy = 'retry'
        maxRetries    = 2
    }
    withName: TIMBR_AGGREGATE {
        cpus   = 4
        memory = '16 GB'
        time   = '30m'
        clusterOptions = '--account=do2_projects --partition=ceres'
    }

    // Optional: DO Mixup QC (optional standalone analysis)
    withName: BROMAN_MIXUP_QC {
        cpus   = 4
        memory = '32 GB'
        time   = '4h'
    }
}

// Execution profiles
profiles {
    
    // HPC/Ceres execution (default)
    standard {
        process.executor = 'slurm'
        apptainer.enabled = true
        apptainer.autoMounts = true
        apptainer.cacheDir = "${projectDir}/singularity_cache"

        executor {
            name = 'slurm'
            queueSize = 500                // Allow all 470 permutation batches to queue
            submitRateLimit = '50/1min'    // Submit 50 jobs per minute to prevent scheduler overload
            pollInterval = '30 sec'        // Check job status more frequently for faster feedback
            queueStatInterval = '5 min'    // More frequent queue updates for progress monitoring
            exitReadTimeout = '5 min'      // Increased from 90sec to allow large file staging (2.1GB alleleprob)
            killBatchSize = 100            // Batch size for killing jobs
            perJobMemLimit = true          // Enable per-job memory limits
        }
    }
    
    // Local execution 
    local {
        process.executor = 'local'
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    
    // Docker profile (for local development)
    docker {
        process.executor = 'local'
        docker.enabled = true
        docker.runOptions = '-u $(id -g):$(id -g)'
    }
    
    // Development/testing profile
    test {
        params.phenotype_file = 'test_data/small_phenotypes.csv'
        params.study_prefix = 'Test'
        params.outdir = 'test_results'
        params.test_mode = true  // Process only chr 19
        
        process {
            cpus = 1
            memory = '2 GB'
            time = '1h'
        }
    }
}

// Reporting and monitoring
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.svg"
    overwrite = true
}

// Cleanup options
cleanup = false  // Set to true in production

// Apptainer settings (primary for HPC)
apptainer {
    enabled = false  // Will be enabled by profile
    autoMounts = true
    cacheDir = "${projectDir}/singularity_cache"
}

// Singularity settings (disabled, keeping for compatibility)
singularity {
    enabled = false
    autoMounts = true
    cacheDir = "${projectDir}/singularity_cache"
}

// Docker settings (for local development)
docker {
    enabled = false  // Will be enabled by profile
    temp = 'auto'
}

// Resource monitoring
monitor {
    enabled = false  // Enable for detailed resource monitoring
}

// Pipeline-level email notifications (one email per pipeline run)
notification {
    enabled = true
    to = 'dpbudke@ucdavis.edu'
}